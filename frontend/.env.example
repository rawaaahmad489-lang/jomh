# رابط الـ Supabase الخاص بمشروعك
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# مفتاح Supabase العام (anon/publishable key) - وليس service role key
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# رابط الباك إند (بدون / في النهاية)
# في التطوير المحلي: http://localhost:3000
# بعد الرفع على Render: https://your-backend-name.onrender.com
VITE_API_URL=http://localhost:3000
