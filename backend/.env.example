# منفذ تشغيل السيرفر (Render سيحدده تلقائياً عبر متغير PORT)
PORT=3000

# مفتاح Groq AI (للشات بوت)
GROQ_API_KEY=your_groq_api_key_here

# مفتاح Gemini (اختياري - مزود بديل غير مستخدم حالياً)
GEMINI_API_KEY=your_gemini_api_key_here

# بيانات Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# رابط الفرونت إند في الإنتاج (لإعدادات CORS)
# بعد الرفع على Vercel: https://your-frontend-name.vercel.app
FRONTEND_URL=http://localhost:5173
